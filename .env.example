# ============================================================
#  Unified AI Health & Fitness Coach — environment template
#  Copy to `.env` and fill in. NEVER commit `.env`.
# ============================================================

# --- WHOOP Cloud API (Adapter A) ----------------------------
# Get these at https://developer.whoop.com
# Create an app, set the redirect URI below, copy the credentials.
# Requires an ACTIVE WHOOP membership.
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=
WHOOP_REDIRECT_URI=http://localhost:8080/callback

# --- Anthropic API (the coach layer) ------------------------
# https://console.anthropic.com — pay-as-you-go.
# NOTE: this is SEPARATE from a Claude.ai subscription; a Pro/Max
# plan does NOT grant API access.
ANTHROPIC_API_KEY=

# --- Local storage ------------------------------------------
# SQLite file location. Relative paths resolve from the repo root.
COACH_DB_PATH=./data/coach.db

# --- User context -------------------------------------------
# Single-user app; user_id is always 1 (multi-tenancy insurance).
COACH_USER_ID=1

# IANA timezone name for the user's HOME timezone.
# Per-record timezones are captured at ingest; this is only the
# fallback when a source doesn't report one.
COACH_HOME_TZ=America/New_York

# Unit system for display: metric | imperial
COACH_UNITS=metric

# --- Logging ------------------------------------------------
# DEBUG | INFO | WARNING | ERROR
COACH_LOG_LEVEL=INFO
